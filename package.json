{
  "name": "stmy-telegram-bot",
  "version": "1.0.0",
  "description": "Superteam MY Telegram onboarding bot - enforces introductions for new members",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:create": "node-pg-migrate create --migration-file-language ts --migrations-dir src/db/migrations"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "node-pg-migrate": "^8.0.4",
    "openai": "^6.29.0",
    "pg": "^8.13.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
